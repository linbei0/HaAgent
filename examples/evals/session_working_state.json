{
  "eval_id": "builtin-session-working-state",
  "case_type": "chat_session",
  "workspace_root": "workspaces/session_working_state",
  "chat": {
    "prompts": [
      "Remember that this task found the setup marker.",
      "Continue after resume and use the bounded working state."
    ]
  },
  "expectations": {
    "final_status": "completed",
    "final_response": {
