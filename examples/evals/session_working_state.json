      "value": "bounded working state"
    },
    "context_contains": [
      "Working State:",
      "current_goal:",
      "last_updated_turn: 1"
    ],
    "context_not_contains": [
      "tool-calls.jsonl",
      "transcript.jsonl",
      "\"tool_name\""
    ]
  },
  "model_responses": [
    {
      "content": "First turn recorded the setup marker.",
      "tool_calls": []
    },
    {
      "content": "The resumed turn used the bounded working state.",
      "tool_calls": []
    }
  ]
}
