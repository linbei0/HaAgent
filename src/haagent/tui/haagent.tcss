Screen {
    layout: vertical;
    background: $background;
    color: $foreground;
}

Screen.theme-light {
    background: $background;
    color: $foreground;
}

Screen.theme-monochrome {
    background: $background;
    color: $foreground;
}

#status-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $foreground;
    text-style: bold;
}

#main {
    height: 1fr;
}

#conversation {
    width: 1fr;
    height: 1fr;
    padding: 1;
    border: solid $panel;
    overflow-y: auto;
}

#input-panel {
    height: 5;
    padding: 0 1;
}

#file-ref-dialog {
    width: 1fr;
    height: 9;
    padding: 0 1;
    border: solid $primary;
    background: $surface;
}

#command-suggestions-dialog {
    width: 1fr;
    height: 9;
    padding: 0 1;
    border: solid $primary;
    background: $surface;
}

#prompt-input {
    width: 1fr;
    height: 4;
}

#footer-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $foreground;
}

#resize-message {
    height: 1fr;
    content-align: center middle;
    padding: 1 2;
    border: solid $warning;
}

#conversation.panel-focused,
#prompt-input.panel-focused {
    border: heavy $primary;
}

.status-default {
    color: $foreground;
}

.status-muted {
    color: $text-muted;
    text-style: dim;
}

.status-emphasis,
.status-focus {
    color: $primary;
    text-style: bold;
}

.status-success {
    color: $success;
    text-style: bold;
}

.status-warning,
.status-pending {
    color: $warning;
    text-style: bold;
}

.status-error,
.status-danger {
    color: $error;
    text-style: bold;
}

.status-info,
.status-running {
    color: $secondary;
    text-style: bold;
}

.status-selection {
    background: $primary;
    color: $background;
    text-style: reverse;
}

.status-cancelled {
    color: $warning;
    text-style: bold;
}

Screen.theme-monochrome .status-default,
Screen.theme-monochrome .status-muted,
Screen.theme-monochrome .status-emphasis,
Screen.theme-monochrome .status-success,
Screen.theme-monochrome .status-warning,
Screen.theme-monochrome .status-error,
Screen.theme-monochrome .status-info,
Screen.theme-monochrome .status-selection,
Screen.theme-monochrome .status-focus,
Screen.theme-monochrome .status-running,
Screen.theme-monochrome .status-cancelled,
Screen.theme-monochrome .status-pending,
Screen.theme-monochrome .status-danger {
    color: $foreground;
}

Screen.theme-monochrome #conversation.panel-focused,
Screen.theme-monochrome #prompt-input.panel-focused {
    border: heavy $foreground;
}

HelpModal,
ToolApprovalModal,
PermissionsModal,
ConfirmModal,
ExternalDirectoryDecisionModal,
SessionOverlay,
SearchOverlay,
SkillPickerOverlay {
    align: center middle;
}

#help-dialog,
#approval-dialog,
#permissions-dialog,
#confirm-dialog,
#external-directory-dialog,
#sessions-dialog,
#search-dialog,
#skill-picker-dialog {
    width: 72;
    height: auto;
    padding: 1 2;
    background: $surface;
}

#help-dialog,
#permissions-dialog,
#external-directory-dialog,
#sessions-dialog,
#search-dialog,
#skill-picker-dialog {
    border: solid $primary;
}

#skill-picker-dialog {
    width: 96%;
}

#approval-dialog,
#confirm-dialog {
    border: solid $warning;
}

#help-title,
#approval-title,
#permissions-title,
#confirm-title,
#external-directory-title {
    text-style: bold;
    margin-bottom: 1;
}

#help-body,
#approval-body,
#permissions-body,
#confirm-body,
#external-directory-body {
    margin-bottom: 1;
}

#approval-buttons {
    align-horizontal: center;
    height: auto;
}

#approval-allow,
#approval-deny {
    margin: 0 2;
}

.action-success {
    text-style: bold;
}

.action-danger {
    text-style: bold reverse;
}

.hidden {
    display: none;
}
