Screen {
    layout: vertical;
    background: $background;
    color: $foreground;
}

Screen.theme-light {
    background: $background;
    color: $foreground;
}

Screen.theme-monochrome {
    background: $background;
    color: $foreground;
}

Screen > .screen--selection {
    background: $primary;
    color: $foreground;
}

#status-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $foreground;
    text-style: none;
}

#main {
    height: 1fr;
    layers: base overlay;
}

#request-history-rail {
    position: absolute;
    layer: overlay;
    offset: 0 0;
    width: 5;
    height: 1fr;
    padding: 1 0 1 1;
    background: $background;
    color: $text-muted;
    overflow: hidden;
}

#request-history-rail:focus {
    color: $foreground;
    background: $surface;
}

#request-history-preview {
    position: absolute;
    layer: overlay;
    width: 56;
    height: auto;
    max-height: 16;
    padding: 1 2;
    background: $surface;
    color: $foreground;
    border-left: solid $primary;
    overflow: hidden;
}

#conversation {
    width: 1fr;
    height: 1fr;
    padding: 1 3;
    border: none;
    background: $background;
    color: $foreground;
    overflow-y: auto;
}

ConversationTimeline {
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
    scrollbar-visibility: hidden;
    scrollbar-background: $background;
    scrollbar-background-hover: $background;
    scrollbar-background-active: $background;
    scrollbar-color: $primary;
    scrollbar-color-hover: $background;
    scrollbar-color-active: $background;
    scrollbar-corner-color: $background;
}

.timeline-placeholder,
.timeline-memory {
    width: 1fr;
    padding: 1 2;
    color: $text-muted;
}

.timeline-item {
    width: 100%;
    height: auto;
    margin-bottom: 1;
    padding: 0 1;
    background: $background;
    color: $foreground;
    border: none;
}

.timeline-user {
    width: 100%;
    min-height: 3;
    margin-left: 0;
    margin-top: 1;
    padding: 1 2 0 2;
    background: $panel;
    border-left: solid $secondary;
}

.timeline-assistant {
    width: 100%;
    margin-left: 0;
    margin-top: 1;
    padding: 0 1;
    background: $background;
    border: none;
}

.timeline-system {
    width: 100%;
    background: $background;
    border: none;
    color: $text-muted;
}

.timeline-activity,
.timeline-effect {
    width: 100%;
    margin-bottom: 0;
    padding: 0 1;
    background: $background;
    border: none;
    color: $text-muted;
}

.timeline-process {
    width: 100%;
    margin-bottom: 0;
    padding: 0 1;
    background: $background;
    border: none;
    color: $text-muted;
}

.timeline-process:hover {
    background: $surface;
}

.timeline-failure,
.timeline-failed {
    background: $surface;
    border-left: solid $error;
}

.timeline-header {
    height: 1;
    margin-bottom: 0;
    margin-left: 0;
    color: $primary;
    text-style: bold;
}

.timeline-user .timeline-header {
    color: $secondary;
}

.timeline-system .timeline-header {
    color: $text-muted;
}

.timeline-activity .timeline-header,
.timeline-effect .timeline-header {
    color: $text-muted;
    text-style: none;
}

.timeline-process .timeline-header {
    color: $text-muted;
    text-style: none;
}

.timeline-failure .timeline-header,
.timeline-failed .timeline-header {
    color: $error;
}

.timeline-body,
.timeline-answer {
    width: 1fr;
    height: auto;
    margin-left: 0;
    margin-bottom: 1;
}

.timeline-assistant Markdown.timeline-body {
    width: 1fr;
    height: auto;
}

.timeline-answer {
    margin-top: 1;
}

.answer-copy-actions {
    width: 1fr;
    height: 1;
    margin: 0 0 1 0;
    align-horizontal: right;
}

.copy-button {
    width: auto;
    min-width: 10;
    height: 1;
    min-height: 1;
    margin: 0;
    padding: 0 1;
    background: $surface;
    color: $text-muted;
    border: none;
}

.copy-button:hover {
    background: $panel;
    color: $foreground;
}

.copy-button:focus {
    background: $primary;
    color: $text;
    text-style: bold;
}

.copyable-code-block > .code-block-toolbar {
    width: 1fr;
    height: 1;
    padding: 0 1;
    background: $surface;
}

.code-block-language {
    width: 1fr;
    height: 1;
    color: $text-muted;
    overflow: hidden;
}

.code-copy-button {
    min-width: 10;
}

.timeline-active {
    height: 1;
    margin-top: 1;
    margin-left: 0;
    color: $secondary;
    text-style: bold;
}

.timeline-streaming {
    border: none;
}

.timeline-tools {
    width: 1fr;
    height: auto;
    margin-top: 1;
    margin-left: 0;
    padding: 0 1;
    background: $background;
    color: $text-muted;
    border: none;
    overflow: hidden;
    scrollbar-background: $background;
    scrollbar-color: $background;
}


#input-panel {
    height: 5;
    padding: 0 3;
}

#progress-status {
    width: 1fr;
    height: 1;
    color: $foreground-muted;
}

.progress-warning {
    color: $warning;
}

.progress-error {
    color: $error;
}

#file-ref-dialog {
    width: 1fr;
    height: 9;
    padding: 0 1;
    border: solid $primary;
    background: $surface;
}

#command-suggestions-dialog {
    width: 1fr;
    height: 9;
    padding: 0 1;
    border: solid $primary;
    background: $surface;
}

#prompt-input {
    width: 1fr;
    height: 4;
    padding: 1 2 0 2;
    border: none;
    border-left: solid $panel;
    background: $surface;
}

#prompt-input:focus,
#prompt-input.panel-focused {
    border: none;
    border-left: solid $primary;
    background: $panel;
}

#context-usage {
    width: 1fr;
    height: 1;
    padding: 0 4;
    color: $foreground-muted;
    text-align: right;
}

#footer-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $foreground;
}

#resize-message {
    height: 1fr;
    content-align: center middle;
    padding: 1 2;
    border: solid $warning;
}

#conversation.panel-focused {
    border: none;
}

Screen.theme-monochrome #conversation.panel-focused,
Screen.theme-monochrome #prompt-input.panel-focused {
    border-left: solid $foreground;
}

Screen.theme-monochrome .timeline-item,
Screen.theme-monochrome .timeline-user,
Screen.theme-monochrome .timeline-assistant,
Screen.theme-monochrome .timeline-system,
Screen.theme-monochrome .timeline-activity,
Screen.theme-monochrome .timeline-process,
Screen.theme-monochrome .timeline-failure,
Screen.theme-monochrome .timeline-failed,
Screen.theme-monochrome .timeline-tools,
Screen.theme-monochrome .timeline-header,
Screen.theme-monochrome .timeline-active {
    color: $foreground;
    border-left: none;
}

Screen.theme-monochrome .timeline-user,
Screen.theme-monochrome .timeline-failure,
Screen.theme-monochrome .timeline-failed {
    border-left: solid $foreground;
}

HelpModal,
ToolApprovalModal,
PermissionsModal,
ConfirmModal,
ExternalDirectoryDecisionModal,
SessionOverlay,
SearchOverlay,
SkillPickerOverlay,
WorkspacePickerOverlay,
ChannelsOverlay {
    align: center middle;
}

#help-dialog,
#approval-dialog,
#permissions-dialog,
#confirm-dialog,
#external-directory-dialog,
#sessions-dialog,
#search-dialog,
#skill-picker-dialog,
#workspace-picker-dialog,
#channels-dialog {
    width: 72;
    height: auto;
    padding: 1 2;
    background: $surface;
}

#help-dialog,
#permissions-dialog,
#external-directory-dialog,
#sessions-dialog,
#search-dialog,
#skill-picker-dialog,
#workspace-picker-dialog,
#channels-dialog {
    border: solid $primary;
}

#skill-picker-dialog {
    width: 96%;
}

#approval-dialog,
#confirm-dialog {
    border: solid $warning;
}

#help-title,
#approval-title,
#permissions-title,
#confirm-title,
#external-directory-title {
    text-style: bold;
    margin-bottom: 1;
}

#help-body,
#approval-body,
#permissions-body,
#confirm-body,
#external-directory-body {
    margin-bottom: 1;
}

#approval-buttons {
    align-horizontal: center;
    height: auto;
}

#approval-allow,
#approval-deny {
    margin: 0 2;
}

.action-success {
    text-style: bold;
}

.action-danger {
    text-style: bold reverse;
}

.hidden {
    display: none;
}
